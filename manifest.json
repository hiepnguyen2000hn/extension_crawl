{
  "manifest_version": 3,
  "name": "Crawl Linked",
  "version": "1.0.1",
  "description": "Crawl network requests and localStorage from any page",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Crawl Linked"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "webRequest",
    "cookies",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}